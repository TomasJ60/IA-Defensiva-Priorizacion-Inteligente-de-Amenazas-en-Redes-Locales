# Entorno de ejemplo para el proyecto
# Copia este archivo a .env y ajusta los valores según el equipo

DJANGO_SECRET_KEY=replace_me_with_secure_secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
SESSION_INACTIVITY_TIMEOUT_SECONDS=900
SESSION_ABSOLUTE_TIMEOUT_SECONDS=28800

DB_NAME=agente_ia
DB_USER=postgres
DB_PASSWORD=admin123
DB_HOST=localhost
DB_PORT=5432

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

VT_API_KEY=
ABUSEIPDB_API_KEY=
GREYNOISE_API_KEY=
OTX_API_KEY=

# IPs que el agente debe monitorizar. Formato CSV.
# Si no se define, el agente por defecto vigila 192.168.100.2 y 192.168.100.10.
MONITORED_IPS=192.168.100.2,192.168.100.10

# Redes que el agente debe monitorizar. Ejemplo: 192.168.100.0/24,10.0.2.0/24
MONITORED_NETWORKS=

IA_CRITICAL_THRESHOLD=85.0
