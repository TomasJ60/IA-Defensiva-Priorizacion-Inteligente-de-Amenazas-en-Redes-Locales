[Unit]
Description=Agente IA Inference Engine
After=network.target postgresql.service agente-ia-agent.service
Requires=postgresql.service
Wants=agente-ia-agent.service

[Service]
Type=simple
WorkingDirectory=/opt/agente-ia/src
Environment=PATH=/opt/agente-ia/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/opt/agente-ia/.venv/bin/python /opt/agente-ia/src/ia_motor.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
