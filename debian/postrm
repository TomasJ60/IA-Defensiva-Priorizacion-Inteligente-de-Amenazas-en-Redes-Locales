#!/bin/sh
set -e

if [ "$1" = "remove" ] || [ "$1" = "purge" ]; then
  if command -v systemctl >/dev/null 2>&1; then
    systemctl disable agente-ia-defensiva-web >/dev/null 2>&1 || true
    systemctl disable agente-ia-defensiva-agent >/dev/null 2>&1 || true
    systemctl disable agente-ia-defensiva-ia >/dev/null 2>&1 || true
    systemctl daemon-reload >/dev/null 2>&1 || true
  fi
fi

exit 0
